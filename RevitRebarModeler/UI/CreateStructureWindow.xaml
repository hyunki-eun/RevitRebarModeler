<Window x:Class="RevitRebarModeler.UI.CreateStructureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="구조물 솔리드 생성" Width="750" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="맑은 고딕">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="구조물 솔리드 생성" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="추출된 JSON 데이터를 기반으로 3D 솔리드를 생성합니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step 1: JSON 파일 선택 -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Step 1. JSON 파일 선택" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="찾아보기" Style="{StaticResource SecBtn}" Width="80" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                    <TextBox x:Name="TxtJsonPath" IsReadOnly="True" VerticalContentAlignment="Center" Height="28"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Step 2: 돌출 설정 -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Step 2. 구조물 두께 설정" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                <TextBlock Text="생성될 3D 솔리드의 두께(돌출 깊이)를 설정합니다." FontSize="11" Foreground="#64748B" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="돌출 깊이 (mm):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtDepth" Text="1000" Width="100" VerticalContentAlignment="Center" Height="24"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Step 3: 영역 선택 리스트 -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Step 3. 생성 영역 선택" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                
                <!-- 상단 버튼 -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="전체 선택" Style="{StaticResource SecBtn}" Click="BtnSelectAll_Click" Margin="0,0,4,0"/>
                    <Button Content="전체 해제" Style="{StaticResource SecBtn}" Click="BtnDeselectAll_Click" Margin="0,0,12,0"/>
                    <TextBlock x:Name="TxtSelectionInfo" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                </StackPanel>

                <!-- 영역 목록 -->
                <ListView x:Name="LstRegions" GridViewColumnHeader.Click="LstRegions_ColumnHeaderClick" BorderBrush="#E2E8F0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <CheckBox x:Name="ChkAll" IsChecked="True" Click="ChkAll_Click"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Click="RegionCheckBox_Click" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="사이클" Width="180" DisplayMemberBinding="{Binding CycleKey}"/>
                            <GridViewColumn Header="영역" Width="50" DisplayMemberBinding="{Binding RegionId}"/>
                            <GridViewColumn Header="면적 (m²)" Width="100" DisplayMemberBinding="{Binding AreaDisplay}"/>
                            <GridViewColumn Header="꼭짓점" Width="60" DisplayMemberBinding="{Binding VertexCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 결과 관련 메시지 표출 영역 -->
        <Border Grid.Row="4" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="상태 요약" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtInfo" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="생성 실행" Style="{StaticResource ActionBtn}" Width="100" Click="BtnCreate_Click" x:Name="BtnCreate" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="취소" Style="{StaticResource SecBtn}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
