<Window x:Class="RevitRebarModeler.UI.TransverseRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="횡방향 철근 배치" Width="820" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="맑은 고딕">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="횡방향 철근 배치" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="JSON의 TransverseRebars를 구조도별 Host에 자동 매칭하여 배치합니다." FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step 1: JSON 파일 선택 -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Step 1. JSON 파일 선택" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="찾아보기" Style="{StaticResource SecBtn}" Width="80" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                    <TextBox x:Name="TxtJsonPath" IsReadOnly="True" VerticalContentAlignment="Center" Height="28"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- Step 2: 구조도별 CTC 설정 -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Step 2. 구조도별 CTC 설정" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                <TextBlock Text="Host 요소는 구조도(N) 패턴으로 자동 매칭됩니다. 돌출 깊이는 Host Comments에서 읽습니다."
                           FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8"/>
                <ListView x:Name="LstCtc" BorderBrush="#E2E8F0" MaxHeight="160">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="구조도" Width="100" DisplayMemberBinding="{Binding SheetKey}"/>
                            <GridViewColumn Header="CTC (mm)" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CtcMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="1Cycle" Width="60" DisplayMemberBinding="{Binding Cycle1Count}"/>
                            <GridViewColumn Header="2Cycle" Width="60" DisplayMemberBinding="{Binding Cycle2Count}"/>
                            <GridViewColumn Header="합계" Width="50" DisplayMemberBinding="{Binding TotalCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <!-- Step 3: 철근 목록 -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Step 3. 배치할 철근 선택" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="전체 선택" Style="{StaticResource SecBtn}" Click="BtnSelectAll_Click" Margin="0,0,4,0"/>
                    <Button Content="전체 해제" Style="{StaticResource SecBtn}" Click="BtnDeselectAll_Click" Margin="0,0,12,0"/>
                    <TextBlock x:Name="TxtSelectionInfo" VerticalAlignment="Center" Foreground="#64748B" FontSize="12"/>
                </StackPanel>
                <ListView x:Name="LstRebars" BorderBrush="#E2E8F0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="40">
                                <GridViewColumn.Header>
                                    <CheckBox x:Name="ChkAll" IsChecked="True" Click="ChkAll_Click"/>
                                </GridViewColumn.Header>
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Click="RebarCheckBox_Click" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                            <GridViewColumn Header="구조도" Width="80" DisplayMemberBinding="{Binding SheetKey}"/>
                            <GridViewColumn Header="사이클" Width="60" DisplayMemberBinding="{Binding CycleNumber}"/>
                            <GridViewColumn Header="규격" Width="60" DisplayMemberBinding="{Binding MatchedText}"/>
                            <GridViewColumn Header="직경" Width="50" DisplayMemberBinding="{Binding DiameterMm}"/>
                            <GridViewColumn Header="세그먼트" Width="60" DisplayMemberBinding="{Binding SegmentCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 상태 -->
        <Border Grid.Row="4" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <TextBlock x:Name="TxtInfo" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="배치 실행" Style="{StaticResource ActionBtn}" Width="100" Click="BtnPlace_Click" x:Name="BtnPlace" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="취소" Style="{StaticResource SecBtn}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
