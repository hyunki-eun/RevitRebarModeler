<Window x:Class="RevitRebarModeler.UI.LongitudinalRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="종방향 철근 배치" Width="1280" Height="720"  MinHeight="720" MaxHeight="720" MaxWidth="1280" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="맑은 고딕">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 배치 실행 (Primary) 전용: 더 진한 녹색 + 볼드 + 큼직한 Padding -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.25" ShadowDepth="1" Color="#064E3B"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#94A3B8"/>
                                <Setter TargetName="Root" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="종방향 철근 배치" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="중심선 교차점을 기준으로 배치. 1번째는 선택한 curve 위, 2번째는 shift 적용."
                       FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step 1: JSON 파일 선택 및 시각화 가이드 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="620"/>
            </Grid.ColumnDefinitions>

            <!-- Step 1: JSON 파일 선택 -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,8,0"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Step 1. JSON 파일 선택" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="찾아보기" Style="{StaticResource SecBtn}" Width="80" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                        <TextBox x:Name="TxtJsonPath" IsReadOnly="True" VerticalContentAlignment="Center" Height="28"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 철근 배치 가이드 다이어그램: Pos1 × Pos2 조합 9개 포인트 매트릭스 -->
            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Padding="12"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Pos1 × Pos2 배치 위치 가이드 (9개 조합)" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Text="각 점은 해당 조합의 실제 배치 좌표. CTC 기준선(Pos1)마다 샘플링 후 shift(Pos2) 적용."
                               FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8"/>
                    <Grid Height="140">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>   <!-- Pos1 레이블 -->
                            <ColumnDefinition Width="*"/>     <!-- 다이어그램 -->
                        </Grid.ColumnDefinitions>

                        <!-- Pos1 레이블 (왼쪽) -->
                        <Grid Grid.Column="0">
                            <TextBlock Text="외측 (Outer)" FontSize="10" FontWeight="SemiBold" Foreground="#1E293B"
                                       VerticalAlignment="Top" Margin="0,18,0,0"/>
                            <TextBlock Text="중앙 (Center)" FontSize="10" FontWeight="SemiBold" Foreground="#1E293B"
                                       VerticalAlignment="Center" Margin="0,8,0,0"/>
                            <TextBlock Text="내측 (Inner)" FontSize="10" FontWeight="SemiBold" Foreground="#1E293B"
                                       VerticalAlignment="Bottom" Margin="0,0,0,18"/>
                        </Grid>

                        <!-- 3개 수평선 + 9개 점 -->
                        <Grid Grid.Column="1">
                            <!-- 수평선 (Pos1 기준 곡선) -->
                            <Line X1="30" Y1="25" X2="480" Y2="25" Stroke="#94A3B8" StrokeThickness="2"/>
                            <Line X1="30" Y1="70" X2="480" Y2="70" Stroke="#CBD5E1" StrokeThickness="1.5" StrokeDashArray="3 2"/>
                            <Line X1="30" Y1="115" X2="480" Y2="115" Stroke="#94A3B8" StrokeThickness="2"/>

                            <!-- 세로 기준선 (Pos2 컬럼) -->
                            <Line X1="90"  Y1="10" X2="90"  Y2="130" Stroke="#E2E8F0" StrokeThickness="1" StrokeDashArray="2 3"/>
                            <Line X1="250" Y1="10" X2="250" Y2="130" Stroke="#E2E8F0" StrokeThickness="1" StrokeDashArray="2 3"/>
                            <Line X1="410" Y1="10" X2="410" Y2="130" Stroke="#E2E8F0" StrokeThickness="1" StrokeDashArray="2 3"/>

                            <!-- 컬럼 헤더 (Pos2 레이블) -->
                            <TextBlock Text="Shift: -offset/2" FontSize="9" Foreground="#475569"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                       Margin="55,-5,0,0" TextAlignment="Center" Width="80"/>
                            <TextBlock Text="Shift: 0" FontSize="9" Foreground="#475569"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                       Margin="220,-5,0,0" TextAlignment="Center" Width="80"/>
                            <TextBlock Text="Shift: +offset/2" FontSize="9" Foreground="#475569"
                                       HorizontalAlignment="Left" VerticalAlignment="Top"
                                       Margin="375,-5,0,0" TextAlignment="Center" Width="80"/>

                            <!-- 9개 포인트 (Pos1 × Pos2 조합) -->
                            <!-- Shift 방향: -offset/2 → 내측쪽(아래로), 0 → 선 위, +offset/2 → 외측쪽(위로) -->

                            <!-- 외측 행 (기준 y=25) -->
                            <Ellipse Width="11" Height="11" Fill="#EF4444"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="85,27,0,0" ToolTip="Pos1=외측, Pos2=-offset/2 (내측쪽으로 shift)"/>
                            <Ellipse Width="11" Height="11" Fill="#EF4444"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="245,20,0,0" ToolTip="Pos1=외측, Pos2=0 (외측 선 위)"/>
                            <Ellipse Width="11" Height="11" Fill="#EF4444"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="405,13,0,0" ToolTip="Pos1=외측, Pos2=+offset/2 (외측쪽으로 shift)"/>

                            <!-- 중앙 행 (기준 y=70) -->
                            <Ellipse Width="11" Height="11" Fill="#8B5CF6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="85,72,0,0" ToolTip="Pos1=중앙, Pos2=-offset/2 (내측쪽으로 shift)"/>
                            <Ellipse Width="11" Height="11" Fill="#8B5CF6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="245,65,0,0" ToolTip="Pos1=중앙, Pos2=0 (중앙 선 위)"/>
                            <Ellipse Width="11" Height="11" Fill="#8B5CF6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="405,58,0,0" ToolTip="Pos1=중앙, Pos2=+offset/2 (외측쪽으로 shift)"/>

                            <!-- 내측 행 (기준 y=115) -->
                            <Ellipse Width="11" Height="11" Fill="#3B82F6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="85,117,0,0" ToolTip="Pos1=내측, Pos2=-offset/2 (내측쪽으로 shift)"/>
                            <Ellipse Width="11" Height="11" Fill="#3B82F6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="245,110,0,0" ToolTip="Pos1=내측, Pos2=0 (내측 선 위)"/>
                            <Ellipse Width="11" Height="11" Fill="#3B82F6"
                                     HorizontalAlignment="Left" VerticalAlignment="Top"
                                     Margin="405,103,0,0" ToolTip="Pos1=내측, Pos2=+offset/2 (외측쪽으로 shift)"/>
                        </Grid>
                    </Grid>
                    <TextBlock FontSize="10" Foreground="#64748B" Margin="0,10,0,0">
                        <Run Text="● " Foreground="#EF4444"/><Run Text="외측 " FontWeight="SemiBold"/>
                        <Run Text="  ● " Foreground="#8B5CF6"/><Run Text="중앙 " FontWeight="SemiBold"/>
                        <Run Text="  ● " Foreground="#3B82F6"/><Run Text="내측 " FontWeight="SemiBold"/>
                        <Run Text="  |  Pos1 = 기준 곡선,  Pos2 = 부호 있는 shift"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Step 2: 구조도별 설정 -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Step 2. 구조도별 설정" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="1번째: 철근 기준 curve (내측/중앙/외측) | 2번째: 1번째에서 radial shift | CTC: 중심 기준 좌우 간격 | 갯수: 구조도당 총 철근 수 (짝수, 4N+2 권장) | offset: 기본값 (D_횡+D_종)/2 — 직경 변경 시 자동 재계산"
                           FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <ListView x:Name="LstSheets" BorderBrush="#E2E8F0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="구조도" Width="80" DisplayMemberBinding="{Binding SheetKey}"/>
                            <GridViewColumn Header="내측 곡선" Width="65" DisplayMemberBinding="{Binding InnerPolylineCount}"/>
                            <GridViewColumn Header="외측 곡선" Width="65" DisplayMemberBinding="{Binding OuterPolylineCount}"/>
                            <GridViewColumn Header="호길이 (mm)" Width="95" DisplayMemberBinding="{Binding ArcLenDisplay}"/>
                            <GridViewColumn Header="1번째 위치" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Pos1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.Pos1Options, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="85" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="2번째 shift" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Pos2Shift, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.Pos2Options, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="115" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="CTC (mm)" Width="85">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CtcMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="70" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="직경" Width="85">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding DiameterLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.DiameterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="70" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="offset (mm)" Width="95">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding OffsetMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="70" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="갯수" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="55" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="상태" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}" CornerRadius="3" Padding="8,3"
                                                HorizontalAlignment="Left" Opacity="0.92">
                                            <TextBlock Text="{Binding StatusText}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding StatusText}"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 상태 -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <TextBlock x:Name="TxtInfo" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="상태 새로고침" Style="{StaticResource SecBtn}" Width="110" Height="38" Click="BtnRevalidate_Click" Margin="0,0,8,0"/>
            <Button Content="배치 실행" Style="{StaticResource PrimaryBtn}" Width="140" Height="44" Click="BtnPlace_Click" x:Name="BtnPlace" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="취소" Style="{StaticResource SecBtn}" Width="80" Height="38" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
