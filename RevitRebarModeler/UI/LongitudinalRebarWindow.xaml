<Window x:Class="RevitRebarModeler.UI.LongitudinalRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="종방향 철근 배치" Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="맑은 고딕">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionBtn">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="종방향 철근 배치" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="중심선 교차점을 기준으로 좌우 대칭 배치. 1번째는 선택한 curve 위, 2번째는 radial shift 적용."
                       FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step 1: JSON 파일 선택 및 시각화 가이드 -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Step 1: JSON 파일 선택 -->
            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,8,0"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Step 1. JSON 파일 선택" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="찾아보기" Style="{StaticResource SecBtn}" Width="80" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                        <TextBox x:Name="TxtJsonPath" IsReadOnly="True" VerticalContentAlignment="Center" Height="28"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- 철근 배치 가이드 다이어그램 -->
            <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="6" Padding="12"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="💡 종방향 위치(Pos) 및 Shift(엇갈림) 가이드" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,10"/>
                    <Grid Height="60">
                        <!-- 터널 단면 층 가이드라인 -->
                        <Line X1="50" Y1="10" X2="340" Y2="10" Stroke="#94A3B8" StrokeThickness="2"/>
                        <TextBlock Text="외측 궤도" FontSize="9" Foreground="#64748B" HorizontalAlignment="Left" Margin="0,-2,0,0" VerticalAlignment="Top"/>

                        <Line X1="50" Y1="30" X2="340" Y2="30" Stroke="#CBD5E1" StrokeThickness="2" StrokeDashArray="3 2"/>
                        <TextBlock Text="중앙 (Center)" FontSize="9" Foreground="#94A3B8" HorizontalAlignment="Left" Margin="0,18,0,0" VerticalAlignment="Top"/>

                        <Line X1="50" Y1="50" X2="340" Y2="50" Stroke="#94A3B8" StrokeThickness="2"/>
                        <TextBlock Text="내측 궤도" FontSize="9" Foreground="#64748B" HorizontalAlignment="Left" Margin="0,38,0,0" VerticalAlignment="Top"/>

                        <!-- 예시 1 -->
                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="80,5,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="105,25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="기준: 외측&#x0a;Shift: -offset/2" FontSize="9" Foreground="#475569" Margin="72,38,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" TextAlignment="Center"/>

                        <!-- 예시 2 -->
                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="180,25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="205,5,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="기준: 중앙&#x0a;Shift: +offset/2" FontSize="9" Foreground="#475569" Margin="172,38,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" TextAlignment="Center"/>

                        <!-- 예시 3 -->
                        <Ellipse Width="10" Height="10" Fill="#EF4444" Margin="280,45,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <Ellipse Width="10" Height="10" Fill="#3B82F6" Margin="305,25,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                        <TextBlock Text="기준: 내측&#x0a;Shift: +offset/2" FontSize="9" Foreground="#475569" Margin="272,3,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" TextAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="* 🔴 1번째 위치 (Pos1)  |  🔵 2번째 위치 (Shift)" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Step 2: 구조도별 설정 -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Step 2. 구조도별 설정" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="1번째: 철근 기준 curve (내측/중앙/외측) | 2번째: 1번째에서 radial shift | CTC: 중심 기준 좌우 간격 | 갯수: 구조도당 총 철근 수 (짝수, 4N+2 권장) | offset: 기본값 (D_횡+D_종)/2 — 직경 변경 시 자동 재계산"
                           FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <ListView x:Name="LstSheets" BorderBrush="#E2E8F0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="구조도" Width="80" DisplayMemberBinding="{Binding SheetKey}"/>
                            <GridViewColumn Header="내측 곡선" Width="65" DisplayMemberBinding="{Binding InnerPolylineCount}"/>
                            <GridViewColumn Header="외측 곡선" Width="65" DisplayMemberBinding="{Binding OuterPolylineCount}"/>
                            <GridViewColumn Header="호길이 (mm)" Width="95" DisplayMemberBinding="{Binding ArcLenDisplay}"/>
                            <GridViewColumn Header="1번째 위치" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Pos1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.Pos1Options, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="85" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="2번째 shift" Width="130">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Pos2Shift, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.Pos2Options, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="115" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="CTC (mm)" Width="85">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CtcMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="70" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="직경" Width="85">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding DiameterLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.DiameterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="70" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="offset (mm)" Width="95">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding OffsetMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="70" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="갯수" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Count, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="55" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="상태" Width="240">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" TextWrapping="Wrap" FontSize="11"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 상태 -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <TextBlock x:Name="TxtInfo" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="상태 새로고침" Style="{StaticResource SecBtn}" Width="110" Click="BtnRevalidate_Click" Margin="0,0,8,0"/>
            <Button Content="배치 실행" Style="{StaticResource ActionBtn}" Width="100" Click="BtnPlace_Click" x:Name="BtnPlace" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="취소" Style="{StaticResource SecBtn}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
