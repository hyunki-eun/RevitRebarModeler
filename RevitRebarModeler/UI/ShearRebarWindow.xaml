<Window x:Class="RevitRebarModeler.UI.ShearRebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="전단철근 배치" Width="980" Height="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="맑은 고딕">

    <Window.Resources>
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="6" Opacity="0.25" ShadowDepth="1" Color="#064E3B"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#047857"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#94A3B8"/>
                                <Setter TargetName="Root" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="SecBtn">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="전단철근 배치" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="횡철근 묶음 + 종철근 단(段) 매핑으로 U자형 전단철근을 자동 배치합니다."
                       FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Step 1: JSON 데이터 (세션 공유) -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Step 1. JSON 데이터" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,8"/>
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="JSON 다시 선택" Style="{StaticResource SecBtn}" Width="120" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
                    <TextBox x:Name="TxtJsonPath" IsReadOnly="True" VerticalContentAlignment="Center" Height="28"/>
                </DockPanel>
                <TextBlock x:Name="TxtSessionInfo" Foreground="#64748B" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Step 2: 구조도별 전단철근 설정 -->
        <Border Grid.Row="2" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Step 2. 구조도별 전단철근 설정" FontSize="14" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,8"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="묶음 수: 횡철근을 N개씩 묶음 (나머지가 N보다 작으면 미배치). 시작 묶음(A/B)부터 홀수 단마다 교대 배치."
                           FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <ListView x:Name="LstSheets" BorderBrush="#E2E8F0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="구조도" Width="80" DisplayMemberBinding="{Binding SheetKey}"/>
                            <GridViewColumn Header="횡방향(단)" Width="80" DisplayMemberBinding="{Binding TransUnitCount}"/>
                            <GridViewColumn Header="종방향(단)" Width="80" DisplayMemberBinding="{Binding LongiUnitCount}"/>
                            <GridViewColumn Header="묶음 수" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding GroupSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="묶음 분할" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GroupPreview}" FontSize="11" Foreground="#475569" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="시작 묶음" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding StartGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.GroupOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="65" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="직경" Width="75">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding DiameterLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.DiameterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="60" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="등급" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Grade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding DataContext.GradeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  Width="65" Height="24"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="후크 길이(mm)" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding HookLengthMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="80" HorizontalAlignment="Center" VerticalContentAlignment="Center" Height="22"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="상태" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}" CornerRadius="3" Padding="8,3"
                                                HorizontalAlignment="Left" Opacity="0.92">
                                            <TextBlock Text="{Binding StatusText}" Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding StatusText}"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <!-- 상태 -->
        <Border Grid.Row="3" Background="White" CornerRadius="6" Padding="14" Margin="0,0,0,8"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <TextBlock x:Name="TxtInfo" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- 하단 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="배치 실행" Style="{StaticResource PrimaryBtn}" Width="140" Height="44" Click="BtnPlace_Click" x:Name="BtnPlace" IsEnabled="False" Margin="0,0,8,0"/>
            <Button Content="취소" Style="{StaticResource SecBtn}" Width="80" Height="38" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
